/* ── Thangka Scroll — Dark ──────────────────────────────────── */
QMainWindow, QWidget {
    background-color: #19130e;
    color: #ecdfc9;
    font-family: "Segoe UI", "Ubuntu", "Noto Sans", "Helvetica Neue", Arial, sans-serif;
    font-size: 13px;
}

QDialog {
    background-color: #19130e;
    color: #ecdfc9;
}

QDialog QLabel {
    color: #ecdfc9;
}

QMessageBox {
    background-color: #19130e;
}

QMessageBox QLabel {
    color: #ecdfc9;
}

QMessageBox QPushButton {
    min-width: 80px;
}

/* ── Sidebar ───────────────────────────────────────────────── */
#sidebar {
    background-color: #120e0a;
}

#sidebar_header {
    background: transparent;
    border-bottom: none;
}

#sidebar_wheel {
    color: #d4891c;
    font-size: 30px;
    padding-bottom: 2px;
}

#sidebar_title {
    color: #eedcb4;
    font-size: 16px;
    font-weight: bold;
    letter-spacing: 1px;
}

#sidebar_sub {
    color: #6a5540;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
}

#sidebar_sep {
    color: #2e2418;
    max-width: 1px;
    background-color: #2e2418;
}

#nav_button {
    color: #b09878;
    background: transparent;
    border: none;
    border-radius: 7px;
    padding: 10px 14px;
    margin-bottom: 2px;
    text-align: left;
    font-size: 13px;
}

#nav_button:hover {
    background-color: #2e2418;
    color: #e0d0b0;
}

#nav_button:checked {
    background-color: #d4891c;
    color: #ffffff;
    font-weight: bold;
}

#sidebar_hint {
    color: #4a3828;
    font-size: 10px;
    font-style: italic;
}

#settings_btn {
    background: transparent;
    color: #8a7860;
    border: 1px solid #3a2e20;
    border-radius: 8px;
    padding: 6px 20px;
    font-size: 13px;
    min-width: 120px;
}

#settings_btn:hover {
    background: #2e2418;
    color: #c0a880;
    border-color: #6b8fbf;
}

#settings_btn:pressed {
    background: #3a2c1e;
}

/* ── View headers ──────────────────────────────────────────── */
#view_header {
    background-color: #19130e;
    border-bottom: 1px solid #2e2016;
}

#view_title {
    font-size: 22px;
    font-weight: bold;
    color: #ecdfc9;
}

#view_sub {
    color: #9e7e61;
    font-size: 12px;
    padding-bottom: 4px;
}

/* ── Today header ──────────────────────────────────────────── */
#today_header {
    background-color: #19130e;
    border-bottom: 1px solid #2e2016;
}

#today_date {
    font-size: 20px;
    font-weight: bold;
    color: #ecdfc9;
}

#today_day {
    font-size: 13px;
    color: #9e7e61;
}

/* ── Quote bar ─────────────────────────────────────────────── */
#quote_bar {
    background-color: #1f1710;
    border-bottom: 1px solid #2e2016;
}

#quote_text {
    color: #6b8fbf;
    font-size: 13px;
    font-style: italic;
    line-height: 1.5;
}

#quote_author {
    color: #7a6040;
    font-size: 11px;
    margin-top: 2px;
}

/* ── Cards / Rows ──────────────────────────────────────────── */
#habit_row, #stat_card, #reflect_card, #chart_card {
    background-color: #261d16;
    border: 1px solid #3a2a1c;
    border-radius: 8px;
}

#habit_row:hover {
    border-color: #6b8fbf50;
    background-color: #2c2218;
}

#stat_card {
    min-width: 120px;
}

/* Ensure text inside stat/reflect cards is readable in dark mode */
#reflect_card QLabel, #stat_card QLabel {
    color: #c8b08a;
}

/* ── Empty label ───────────────────────────────────────────── */
#empty_label {
    color: #7a5a3a;
    font-size: 13px;
    padding: 40px;
    qproperty-alignment: AlignCenter;
}

/* ── Checkboxes ────────────────────────────────────────────── */
QCheckBox {
    spacing: 8px;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border: 2px solid #5a4830;
    border-radius: 5px;
    background: #1f1710;
}

QCheckBox::indicator:checked {
    background-color: #6b8fbf;
    border-color: #6b8fbf;
}

QCheckBox::indicator:hover {
    border-color: #6b8fbf;
}

/* ── Buttons ───────────────────────────────────────────────── */
QPushButton {
    background-color: #d4891c;
    color: white;
    border: none;
    border-radius: 7px;
    padding: 7px 18px;
    font-size: 12px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #e09820;
}

QPushButton:pressed {
    background-color: #b5503c;
}

QPushButton#secondary_btn {
    background-color: transparent;
    color: #9e7e61;
    border: 1px solid #4a3a28;
    font-weight: normal;
    padding: 6px 14px;
}

QPushButton#secondary_btn:hover {
    background-color: #2e2418;
    color: #c0a880;
    border-color: #6b8fbf60;
}

/* ── Inputs ────────────────────────────────────────────────── */
QLineEdit, QTextEdit, QPlainTextEdit, QTimeEdit {
    background-color: #221810;
    border: 1px solid #4a3828;
    border-radius: 7px;
    padding: 8px 10px;
    color: #ecdfc9;
    selection-background-color: #6b8fbf;
    selection-color: white;
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus, QTimeEdit:focus {
    border-color: #6b8fbf;
    outline: none;
}

QTimeEdit::up-button, QTimeEdit::down-button {
    width: 16px;
    border: none;
    background: transparent;
}

/* ── Form layout labels ────────────────────────────────────── */
QFormLayout > QLabel, QFormLayout QLabel {
    color: #b09070;
    font-size: 12px;
    font-weight: 500;
}

/* ── ComboBox ──────────────────────────────────────────────── */
QComboBox {
    background-color: #221810;
    border: 1px solid #4a3828;
    border-radius: 7px;
    padding: 6px 10px;
    color: #ecdfc9;
    min-width: 140px;
}

QComboBox:focus {
    border-color: #6b8fbf;
}

QComboBox::drop-down {
    border: none;
    padding-right: 8px;
}

QComboBox QAbstractItemView {
    background: #221810;
    border: 1px solid #4a3828;
    border-radius: 6px;
    color: #ecdfc9;
    selection-background-color: #6b8fbf30;
    selection-color: #ecdfc9;
}

/* ── Scroll areas ──────────────────────────────────────────── */
QScrollArea {
    background: transparent;
    border: none;
}

QScrollArea > QWidget > QWidget {
    background: transparent;
}

/* ── Scrollbars ────────────────────────────────────────────── */
QScrollBar:vertical {
    background: transparent;
    width: 8px;
    border-radius: 4px;
}

QScrollBar::handle:vertical {
    background: #4a3828;
    border-radius: 4px;
    min-height: 24px;
}

QScrollBar::handle:vertical:hover {
    background: #6b8fbf50;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: transparent;
}

QScrollBar:horizontal {
    height: 0;
}

/* ── Dialog ────────────────────────────────────────────────── */
#dialog_title {
    font-size: 17px;
    font-weight: bold;
    color: #ecdfc9;
    padding-bottom: 4px;
}

/* ── Reflect ───────────────────────────────────────────────── */
#reflect_prompt {
    font-size: 14px;
    font-weight: bold;
    color: #c8b08a;
}

#reflect_edit {
    background-color: #221810;
    border: 1px solid #4a3828;
    border-radius: 6px;
}

/* ── Meditation ────────────────────────────────────────────── */
#meditation_timer {
    font-size: 52px;
    font-weight: 200;
    color: #ecdfc9;
    letter-spacing: 4px;
}

#meditation_hint {
    color: #7a6040;
    font-size: 12px;
    font-style: italic;
}

/* ── ToolTip ───────────────────────────────────────────────── */
QToolTip {
    background-color: #261d16;
    color: #ecdfc9;
    border: 1px solid #6b8fbf;
    border-radius: 5px;
    padding: 4px 8px;
    font-size: 12px;
}
